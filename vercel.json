{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.remonttireitti.fi" }],
      "destination": "https://remonttireitti.fi/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/expire-listings",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/expire-pending-acceptances",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/review-reminders",
      "schedule": "0 6 * * *"
    }
  ]
}
