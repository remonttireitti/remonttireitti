# Kopioi: copy secrets.yaml.example secrets.yaml

# Vaihtoehto A: täytä kotiverkko
wifi_ssid: "KOTIVERKKO"
wifi_password: "SALASANA"

# Vaihtoehto B: jätä väärät arvot -> laite avaa 5 min kuluttua
# WiFi-verkon "Alykoti-Setup" (salasana: alykoti-ota)
# Avaa selaimessa http://192.168.4.1 ja valitse verkko

# Airthings: CO2 tulee pilvi-API:sta (web .env.local). BLE-MAC ei pakollinen.

device_token: "KOPIOI_WEBISTA"
device_auth: "Bearer KOPIOI_SAMA_TOKEN"

# Julkaistu web (Vercel):
# sync_url: "https://alykoti.vercel.app/api/device/sync"

airfi_modbus_host: "192.168.50.26"

ota_password: "alykoti-ota"
api_encryption_key: "GENEROI_ESPHOME_KOMENNOLLA"
