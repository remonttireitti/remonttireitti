# Pakollinen — kopioi webistä Keskusyksikkö → device token
ALYKOTI_DEVICE_TOKEN=
ALYKOTI_SYNC_URL=https://alykoti.vercel.app/api/device/sync
SYNC_INTERVAL_SEC=30

# AirFi Modbus RTU (MAX485 → IV-kone MODBUS A/B)
AIRFI_MODBUS_SERIAL=/dev/ttyAMA2
AIRFI_MODBUS_BAUD=9600
AIRFI_MODBUS_UNIT=1
# 1 = lue IV-koneelta (suositus). 0 = Modbus pois.
AIRFI_ENABLED=1
# 0 = vain luku (turvallinen). 1 = sallii set_fan_pct / set_away IV:hen.
AIRFI_WRITES_ENABLED=0

# Paikallinen Mosquitto (Docker stack)
MQTT_URL=mqtt://127.0.0.1:1883
SKYCONNECT_TOPIC_PREFIX=zigbee2mqtt
