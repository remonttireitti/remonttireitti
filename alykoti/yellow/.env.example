# AirFi IV — Modbus TCP lähiverkossa (ei RS485-adapteria Yellowlla)
AIRFI_MODBUS_HOST=192.168.50.26
AIRFI_MODBUS_PORT=502
AIRFI_MODBUS_UNIT=1
# Lyhyet TCP-yhteydet — timeoutit sekunteina, backoff kun offline
AIRFI_CONNECT_TIMEOUT_SEC=4
AIRFI_READ_TIMEOUT_SEC=5
AIRFI_RETRY_COUNT=1
AIRFI_OFFLINE_BACKOFF_MAX_SEC=180
AIRFI_ENABLED=1
# 0 = vain luku. 1 = sallii tuuletin/poissa-komennot IV:hen.
AIRFI_WRITES_ENABLED=0

# Nopea komentosynkki (s) — laitteet heti, täysi tila-SYNC_INTERVAL_SEC välein
COMMAND_POLL_ENABLED=1
COMMAND_POLL_INTERVAL_SEC=5

# Vaihtoehto: sarja RTU (jos joskus MAX485)
# AIRFI_MODBUS_SERIAL=/dev/ttyAMA2
# AIRFI_MODBUS_BAUD=9600
