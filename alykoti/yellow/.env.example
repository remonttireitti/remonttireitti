# AirFi IV — Modbus TCP lähiverkossa + RTU-varapolku Yellowlla
AIRFI_MODBUS_HOST=192.168.50.26
AIRFI_MODBUS_PORT=502
AIRFI_MODBUS_UNIT=1
# TCP ensin, sitten sarja jos TCP ei vastaa
AIRFI_MODBUS_SERIAL=/dev/ttyAMA2
AIRFI_MODBUS_BAUD=38400
# Lyhyet TCP-yhteydet — timeoutit sekunteina, backoff kun offline
AIRFI_CONNECT_TIMEOUT_SEC=3
AIRFI_READ_TIMEOUT_SEC=3
AIRFI_RETRY_COUNT=3
AIRFI_RETRY_DELAY_SEC=1
AIRFI_MODBUS_TCP_GAP_MS=30
AIRFI_MODBUS_CONNECT_DELAY_SEC=1
AIRFI_MODBUS_RETRIES=3
AIRFI_MODBUS_DELAY_SEC=3
AIRFI_OFFLINE_BACKOFF_MAX_SEC=60
AIRFI_OFFLINE_SKIP_AFTER=5
AIRFI_CACHE_MAX_AGE_SEC=300
AIRFI_ENABLED=1
# 0 = vain luku. 1 = sallii tuuletin/poissa-komennot IV:hen.
AIRFI_WRITES_ENABLED=0

# Nopea komentosynkki (s) — komennot + Shelly EM, täysi tila SYNC_INTERVAL_SEC välein
COMMAND_POLL_ENABLED=1
COMMAND_POLL_INTERVAL_SEC=5
ENERGY_QUICK_POLL_SEC=10

# Suora Supabase — automaatiot ja integraatiot ilman Verceliä
# Kopioi Vercel/S Supabase → Settings → API
SUPABASE_URL=https://vgxjobyfbpzriofcbcis.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_REFRESH_SEC=300
